# ============================================================
# PRIMESERVE — ENVIRONMENT VARIABLE REFERENCE
# Copy this file to .env.local and fill in your real values.
# This file IS committed to Git — never put real secrets here.
# ============================================================

# ------ Supabase -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------ Firebase (Auth ONLY) -----------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ------ Firebase Admin SDK (server-side) -----------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ------ App ----------------------------------------------------
SESSION_SECRET=generate_with_openssl_rand_base64_32
# Webhook signature secret — used to verify inbound webhook requests
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=generate_with_openssl_rand_hex_32
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Razorpay -----------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
